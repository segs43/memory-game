{
  "name": "memory-thief",
  "version": "2.0.0",
  "description": "Memory Thief — Professional horror game platform by TawsiN",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node src/backend/server.js\"",
    "dev:client": "vite",
    "dev:server": "node src/backend/server.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pixi.js": "^8.1.0",
    "zustand": "^4.5.2",
    "howler": "^2.2.4",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/howler": "^2.2.11",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}